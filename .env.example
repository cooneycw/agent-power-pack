# agent-power-pack environment variables
# Copy to .env and fill in values for local development.

# --- LLM provider keys (used by second-opinion MCP server) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Plane (project management) ---
PLANE_BASE_URL=https://plane.example.com
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=

# --- Wiki.js (documentation) ---
WIKIJS_BASE_URL=https://wiki.example.com
WIKIJS_API_TOKEN=

# --- AWS Secrets Manager sidecar ---
# The sidecar reads credentials from the standard AWS credential chain.
# These are only needed if running the sidecar outside of an EC2/ECS context.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
